# ============================================
# Pulse-Check API — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://pulse_user:your_password_here@localhost:5433/pulse_check_db

# ============================================
# AI CONFIGURATION (Anthropic Claude)
# ============================================
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Master API key for backward compatibility
# Generate a strong random key for production
API_KEY=your-master-api-key-here

# Master key for API key management endpoints
# Generate a strong random key for production
MASTER_KEY=your-master-key-here

# JWT Configuration
# Generate a strong random secret key for production
# Example: openssl rand -hex 32
SECRET_KEY=your-jwt-secret-key-here

# JWT Algorithm (recommended: HS256)
ALGORITHM=HS256

# JWT token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# NOTES
# ============================================
# Never commit .env to version control
# Always use strong random keys in production
# Rotate keys regularly for security
